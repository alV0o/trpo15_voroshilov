<Page x:Class="trpo15_voroshilov.Pages.AddEditProductPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:trpo15_voroshilov.Pages"
      xmlns:validators="clr-namespace:trpo15_voroshilov.Validators"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddEditProductPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="5*"/>
        </Grid.RowDefinitions>

        <Button VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10" Content="&lt;" Click="BackBtn_Click"/>
        <Label Content="Создание" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30"/>
        <ScrollViewer Grid.Row="1" Grid.Column="1">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Название"/>
                <TextBox x:Name="nameBox" Grid.Row="1">
                    <Binding Path="Product.Name" UpdateSourceTrigger="PropertyChanged">
                        <Binding.ValidationRules>
                            <validators:EmptyValidation ValidatesOnTargetUpdated="True"/>
                        </Binding.ValidationRules>
                    </Binding>
                </TextBox>
                <TextBlock Grid.Row="2" Text="Описание"/>
                <TextBox x:Name="descBox" Grid.Row="3">
                    <Binding Path="Product.Description" UpdateSourceTrigger="PropertyChanged">
                        <Binding.ValidationRules>
                            <validators:EmptyValidation ValidatesOnTargetUpdated="True"/>
                        </Binding.ValidationRules>
                    </Binding>
                </TextBox>
                <TextBlock Grid.Row="4" Text="Количество"/>
                <TextBox x:Name="stockBox" Grid.Row="5">
                    <Binding Path="Product.Stock" UpdateSourceTrigger="PropertyChanged">
                        <Binding.ValidationRules>
                            <validators:EmptyValidation ValidatesOnTargetUpdated="True"/>
                            <validators:CorrectIntValidation ValidatesOnTargetUpdated="True"/>
                        </Binding.ValidationRules>
                    </Binding>
                </TextBox>
                <TextBlock Grid.Row="6" Text="Цена"/>
                <TextBox x:Name="priceBox" Grid.Row="7">
                    <Binding Path="Product.Price" UpdateSourceTrigger="PropertyChanged" StringFormat="0.0#">
                        <Binding.ValidationRules>
                            <validators:EmptyValidation ValidatesOnTargetUpdated="True"/>
                            <validators:PriceValidation ValidatesOnTargetUpdated="True"/>
                        </Binding.ValidationRules>
                    </Binding>
                </TextBox>
                <TextBlock Grid.Row="8" Text="Рейтинг"/>
                <TextBox x:Name="ratingBox" Grid.Row="9">
                    <Binding Path="Product.Rating" UpdateSourceTrigger="PropertyChanged" StringFormat="0.0"> 
                        <Binding.ValidationRules>
                            <validators:EmptyValidation ValidatesOnTargetUpdated="True"/>
                            <validators:RatingValidation ValidatesOnTargetUpdated="True"/>
                        </Binding.ValidationRules>
                    </Binding>
                </TextBox>
                <TextBlock Grid.Row="10" Text="Бренд"/>
                <ComboBox Grid.Row="11" ItemsSource="{Binding Brands}" SelectedItem="{Binding Product.Brand, UpdateSourceTrigger=PropertyChanged}" DisplayMemberPath="Name" />
                <TextBlock Grid.Row="12" Text="Категория"/>
                <ComboBox Grid.Row="13" ItemsSource="{Binding Categories}" SelectedItem="{Binding Product.Category, UpdateSourceTrigger=PropertyChanged}" DisplayMemberPath="Name"/>
                <Grid Grid.Row="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                        <TextBlock Text="Добавленные теги"/>
                        <ListBox ItemsSource="{Binding Product.Tags}" MouseDoubleClick="RemoveTag_MouseDoubleClick">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                        <TextBlock Text="Доступные теги"/>
                        <ListBox ItemsSource="{Binding Tags}" MouseDoubleClick="AddTag_MouseDoubleClick">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Grid>
                <Button Grid.Row="15" Content="Сохранить" Click="Save_Click"/>
                <Button Grid.Row="16" Content="Сбросить" Click="Reset_Click"/>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
