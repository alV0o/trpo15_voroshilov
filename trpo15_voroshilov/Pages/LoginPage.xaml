<Page x:Class="trpo15_voroshilov.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:trpo15_voroshilov.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Авторизация"
      DataContext="{Binding RelativeSource={RelativeSource Self}}">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <Label Content="Введите пин-код"/>
            <TextBox Text="{Binding pinCode,UpdateSourceTrigger=PropertyChanged}"/>
            <Button Content="Войти" Click="To_ManagerPage"/>
            <Button Content="Войти как пользователь" Click="To_ClientPage"/>
        </StackPanel>
    </Grid>
</Page>
